{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "composite": false,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@grc/ui": [
        "../../packages/ui/src"
      ],
      "@grc/contracts": [
        "../../packages/contracts/src"
      ],
      "@grc/i18n": [
        "../../packages/i18n/src"
      ]
    },
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
