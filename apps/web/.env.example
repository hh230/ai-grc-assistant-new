# @grc/web environment configuration. Copy to .env.local (dev) or set in your secret
# manager (prod). Never commit real secrets.

# ── Auth ────────────────────────────────────────────────────────────────────
# Session signing key for the authentication layer (HS256 JWT in an httpOnly cookie).
# REQUIRED in production; must be at least 32 characters. Generate one with:
#   openssl rand -base64 48
AUTH_SECRET=

# ── AI provider (P4 analysis, P5 chat) ──────────────────────────────────────
# Provider selection: "openai" (default when OPENAI_API_KEY is set) or "local"
# (deterministic, no-egress fallback — no customer data leaves the tenant).
# AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (with the pgvector extension) — backs every repository adapter (documents,
# evidence, analyses, document chunk embeddings, conversations, policies, risks). REQUIRED.
# Run `pnpm db:migrate` after pointing this at a fresh database.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aigrc

# ── Storage ─────────────────────────────────────────────────────────────────
# Root directory for uploaded document/evidence blobs (object storage adapter). Defaults to
# "<app>/.data". Point this at a persistent volume in production, or replace the blob-store
# adapter with S3/GCS.
# STORAGE_DIR=/var/lib/grc/data

# ── Backend API (future integration) ────────────────────────────────────────
# Base URL of the FastAPI backend for server-side proxying.
# GRC_API_BASE_URL=http://localhost:8000

# ── Email (KI-P9 access onboarding — invitation emails) ─────────────────────
# Resend API key. Server-side only — never exposed to the browser (lib/email/client.ts is
# the only place this is read). Without it, sending fails gracefully: approving an access
# request still creates the invitation and shows its copyable link.
RESEND_API_KEY=
# The "From" address/display name Resend sends as, e.g. "Rasheed <noreply@rasheed.sa>".
# Must be a verified sender/domain in your Resend account.
EMAIL_FROM=
