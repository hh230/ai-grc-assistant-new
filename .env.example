# ============================================================
# AI GRC Assistant — example environment (copy to .env)
# Secrets must come from a secret manager in real environments.
# ============================================================

# ---- App ----
APP_ENV=local

# ---- PostgreSQL (with pgvector) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=grc
POSTGRES_USER=grc
POSTGRES_PASSWORD=grc_local_password
DATABASE_URL=postgresql+asyncpg://grc:grc_local_password@localhost:5432/grc

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- apps/api dev auth bridge ----
# Maps apps/web's seeded dev bearer tokens (apps/web/lib/auth/users.ts) to the Principal claims
# apps/api's StaticTokenAuthenticator expects — one entry per apps/web dev user/role, all under
# the same tenant. In production this is empty and a real OIDC/JWT authenticator is bound
# instead (default deny — see apps/api/src/grc_api/security/authentication.py).
# API_AUTH_TOKENS='{"<token>":{"user_id":"...","organization_id":"...","roles":["..."]}, ...}'

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- LLM providers (placeholders — set in secret manager) ----
# Selected provider: OpenAI (ADR/ADL-0009). grc_llm reads these from the environment.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional overrides (defaults shown):
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
# OPENAI_BASE_URL=            # optional; for Azure/OpenAI-compatible gateways

# ---- Event bus (placeholder) ----
EVENT_BUS_URL=
