{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@grc/web", "start"],
      "port": 3000
    },
    {
      "name": "web-dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@grc/web", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "api-dev",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "grc_api.app:create_app", "--factory", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "worker-dev",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "grc_worker.knowledge_learning_loop"],
      "port": 8090
    },
    {
      "name": "regulation-ingestion-dev",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "grc_worker.regulation_ingestion_loop"],
      "port": 8091
    }
  ]
}
